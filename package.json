{
	"name": "freelance-tracker",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n server,browser -c magenta,cyan \"npm run dev:server\" \"npm run dev:browser\"",
		"dev:server": "NODE_ENV=development tsx watch server.ts",
		"dev:browser": "esbuild app/assets/entry.tsx --outdir=public/assets --bundle --format=esm --sourcemap --watch",
		"build": "tsc --noEmit && npm run build:browser",
		"build:browser": "esbuild app/assets/entry.tsx --outdir=public/assets --bundle --format=esm --minify",
		"start": "tsx server.ts",
		"format": "biome format .",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"better-sqlite3": "^12.6.2",
		"concurrently": "^9.2.1",
		"remix": "3.0.0-alpha.4",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.2",
		"esbuild": "^0.25.0",
		"typescript": "~5.9.3"
	}
}
